# Production Environment Variables

# Database
POSTGRES_DB=finance_ai
POSTGRES_USER=finance_ai_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# JWT - Use strong random strings (min 32 chars)
JWT_SECRET=CHANGE_THIS_TO_RANDOM_STRING_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_STRING_MIN_32_CHARS

# API Keys
ANTHROPIC_API_KEY=sk-ant-api03-your-production-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
COINGECKO_API_KEY=your-coingecko-key

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Frontend URL
FRONTEND_URL=https://your-domain.com
